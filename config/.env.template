# MetaClaw Environment Configuration
# Copy to your project root as .env and fill in values
# chmod 600 after editing

# --- Assistant ---
ASSISTANT_NAME=Andy
# TRIGGER_WORD defaults to ASSISTANT_NAME if not set

# --- Timezone ---
# Set to your local timezone (e.g., America/New_York, Europe/London, Asia/Tokyo)
TZ=UTC

# --- Telegram (optional) ---
# Get a token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=<from-botfather>
# TELEGRAM_ONLY=true  # Set to true if not using WhatsApp

# --- Container ---
# CONTAINER_IMAGE=metaclaw-agent:latest
# CONTAINER_TIMEOUT=1800000          # 30min hard kill timeout
# IDLE_TIMEOUT=1800000               # 30min keep-alive after last result
# MAX_CONCURRENT_CONTAINERS=5

# --- Environment ---
NODE_ENV=production

# --- Claude Auth ---
# OAuth is handled via ~/.claude/.credentials.json (from `claude` login)
# No API key needed — Max plan OAuth is used
