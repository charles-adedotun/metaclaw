# MetaClaw Environment
# Copy to .env and fill in values

# Your assistant's name — this is what you'll type to trigger it (e.g., @Jarvis, @Friday, @Max)
ASSISTANT_NAME=Assistant
TZ=UTC
NODE_ENV=production

# Telegram (optional — get token from @BotFather)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ONLY=true
